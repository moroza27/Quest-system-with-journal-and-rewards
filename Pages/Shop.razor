@page "/shop"
@implements IDisposable
@using SweetBakeryQuest.Models
@using SweetBakeryQuest.Services
@inject GameState State

<style>
    /* Стилі для спливаючого вікна доставки (на весь екран) */
    .delivery-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.6);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 1000;
        backdrop-filter: blur(3px);
    }

    .delivery-modal {
        background: #fff;
        padding: 30px;
        border-radius: 15px;
        text-align: center;
        min-width: 300px;
        border: 4px solid #fbc02d;
        box-shadow: 0 10px 25px rgba(0,0,0,0.3);
    }
</style>

<div class="container mt-4">
    <h3 class="text-center mb-4" style="color: #4e342e; font-weight: bold;">🛒 Ринок Інгредієнтів</h3>

    @if (showErrorMessage)
    {
        <div class="alert alert-danger text-center fw-bold shadow-sm">
            ❌ Недостатньо монет для покупки!
        </div>
    }

    <div class="row justify-content-center">
        <div class="col-md-4 mb-3">
            <div class="card p-3 shadow-sm text-center" style="border-radius: 15px; border: 2px dashed #8d6e63;">
                <h4 style="color: #5d4037;">🌾 Борошно</h4>
                <p class="fs-5 mb-3">Ціна: <strong>10 💰</strong></p>

                <button class="btn btn-warning fw-bold w-100"
                        disabled="@isDelivering"
                        @onclick="@(() => BuyItem(ProductType.Flour, 10, 5, "Борошно"))">
                    Купити (Доставка: 5 сек)
                </button>
            </div>
        </div>
    </div>
</div>

@if (isDelivering)
{
    <div class="delivery-overlay">
        <div class="delivery-modal">
            <h2 class="mb-3">🚚 Доставка...</h2>
            <h4 style="color: #5d4037;">Вантаж: @deliveryItemName</h4>

            <div class="display-4 fw-bold text-warning my-3">
                @deliverySecondsRemaining сек
            </div>

            <div class="progress mt-3" style="height: 25px;">
                <div class="progress-bar progress-bar-striped progress-bar-animated bg-warning"
                     role="progressbar"
                     style="width: 100%">
                </div>
            </div>
        </div>
    </div>
}

@code {
    // Змінні для керування доставкою
    private bool isDelivering = false;
    private int deliverySecondsRemaining = 0;
    private string deliveryItemName = "";

    // Змінна для помилки
    private bool showErrorMessage = false;
    private bool isDisposed = false;

    protected override void OnInitialized() => State.OnChange += StateHasChanged;

    public void Dispose()
    {
        isDisposed = true;
        State.OnChange -= StateHasChanged;
    }

    private async Task BuyItem(ProductType type, int price, int deliveryTime, string itemName)
    {
        // 1. Пробуємо списати гроші
        bool success = State.SpendGold(price);

        if (success)
        {
            // Ховаємо помилку, якщо вона була
            showErrorMessage = false;

            // 2. Запускаємо візуал доставки
            isDelivering = true;
            deliveryItemName = itemName;
            deliverySecondsRemaining = deliveryTime;
            StateHasChanged();

            // 3. Таймер (Цикл, який віднімає по 1 секунді)
            while (deliverySecondsRemaining > 0)
            {
                await Task.Delay(1000); // Чекаємо 1 секунду
                deliverySecondsRemaining--;

                // Перевіряємо, чи гравець не пішов зі сторінки, щоб не було помилок
                if (!isDisposed)
                {
                    StateHasChanged();
                }
            }

            // 4. Доставка завершена! Додаємо товар на склад
            State.AddToInventory(type, 1);
            isDelivering = false;

            if (!isDisposed)
            {
                StateHasChanged();
            }
        }
        else
        {
            // Якщо грошей не вистачило
            showErrorMessage = true;
            await Task.Delay(2000); // Показуємо помилку 2 секунди
            showErrorMessage = false;

            if (!isDisposed) StateHasChanged();
        }
    }
}