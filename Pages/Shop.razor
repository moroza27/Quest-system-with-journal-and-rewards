@page "/shop"
@implements IDisposable
@using SweetBakeryQuest.Models
@using SweetBakeryQuest.Services
@inject GameState State

<style>
    /* Стиль для заблокованих товарів як у довіднику */
    .locked-product {
        opacity: 0.6;
        filter: grayscale(80%);
        position: relative;
        cursor: not-allowed;
    }

    .lock-icon {
        position: absolute;
        top: 10px;
        right: 10px;
        font-size: 1.5rem;
    }

    .delivery-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.6);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 1000;
        backdrop-filter: blur(3px);
    }

    .delivery-modal {
        background: #fff;
        padding: 30px;
        border-radius: 15px;
        text-align: center;
        min-width: 300px;
        border: 4px solid #fbc02d;
    }
</style>

<div class="container mt-4" style="margin-bottom: 120px;">
    <h3 class="text-center mb-4" style="color: #4e342e; font-weight: bold;">🛒 Ринок Інгредієнтів</h3>

    @if (showErrorMessage)
    {
        <div class="alert alert-danger text-center fw-bold shadow-sm">
            ❌ Недостатньо монет для оплати всього кошика!
        </div>
    }

    <div class="row">
        <div class="@(cart.Count > 0 ? "col-md-8" : "col-md-12")" style="transition: all 0.3s ease-in-out;">
            <div class="row justify-content-center">
                @foreach (var item in AvailableProducts)
                {
                    // ПЕРЕВІРКА РІВНЯ (CurrentLevel замість репутації)
                    bool isUnlocked = State.CurrentLevel >= item.RequiredLevel;

                    <div class="col-md-4 col-sm-6 mb-3">
                        <div class="card p-3 shadow-sm text-center h-100 @(isUnlocked ? "" : "locked-product")"
                             style="border-radius: 15px; border: 2px dashed #8d6e63; background-color: #fdf8e4;">

                            @if (!isUnlocked)
                            {
                                <div class="lock-icon">🔒</div>
                            }

                            <div class="display-4 mb-2">@item.Icon</div>
                            <h5 style="color: #5d4037; font-weight: bold;">@item.Name</h5>

                            @if (isUnlocked)
                            {
                                <p class="fs-6 mb-3">Ціна: <strong>@item.Price 💰</strong></p>
                                <button class="btn btn-outline-success fw-bold w-100 mt-auto"
                                        disabled="@isDelivering"
                                        @onclick="@(() => AddToCart(item.Type))">
                                    + В кошик
                                </button>
                            }
                            else
                            {
                                <p class="text-muted mt-2">Відкриється на<br /><strong>@item.RequiredLevel рівні</strong></p>
                                <button class="btn btn-secondary w-100 mt-auto" disabled>Заблоковано</button>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>

        @if (cart.Count > 0)
        {
            <div class="col-md-4">
                <div class="card p-3 shadow" style="border-radius: 15px; border: 2px solid #fbc02d; background-color: #fffde7;">
                    <h4 class="text-center mb-3" style="color: #f57f17; font-weight: bold;">🛒 Ваш Кошик</h4>
                    <ul class="list-group list-group-flush mb-3" style="background: transparent;">
                        @foreach (var cartItem in cart)
                        {
                            var product = AvailableProducts.First(p => p.Type == cartItem.Key);
                            <li class="list-group-item d-flex justify-content-between align-items-center" style="background: transparent; border-bottom-color: #ffe082;">
                                <span>@product.Icon @product.Name</span>
                                <div>
                                    <button class="btn btn-sm btn-danger" @onclick="@(() => RemoveFromCart(product.Type))">-</button>
                                    <span class="mx-2 fw-bold">@cartItem.Value</span>
                                    <button class="btn btn-sm btn-success" @onclick="@(() => AddToCart(product.Type))">+</button>
                                </div>
                            </li>
                        }
                    </ul>
                    <hr />
                    <div class="d-flex justify-content-between mb-2">
                        <span>Всього товарів:</span>
                        <strong>@TotalCartItems шт.</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2 text-danger">
                        <span>До оплати:</span>
                        <strong>@TotalCartPrice 💰</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-3 text-primary">
                        <span>Доставка:</span>
                        <strong>@TotalDeliveryTime сек ⏱️</strong>
                    </div>

                    <button class="btn btn-warning fw-bold w-100 fs-5"
                            disabled="@isDelivering"
                            @onclick="Checkout">
                        Замовити доставку 🚚
                    </button>
                </div>
            </div>
        }
    </div>
</div>

@if (isDelivering)
{
    <div class="delivery-overlay">
        <div class="delivery-modal shadow-lg">
            <h2 class="mb-3">🚚 Доставка опту...</h2>
            <div class="display-4 fw-bold text-warning my-3">@deliverySecondsRemaining сек</div>
            <div class="progress mt-3" style="height: 15px;">
                <div class="progress-bar progress-bar-striped progress-bar-animated bg-warning"
                     role="progressbar" style="width: 100%"></div>
            </div>
        </div>
    </div>
}

@code {
    private bool isDelivering = false;
    private int deliverySecondsRemaining = 0;
    private bool showErrorMessage = false;
    private bool isDisposed = false;
    private Dictionary<ProductType, int> cart = new();

    // ОНОВЛЕНИЙ КАТАЛОГ: Використовуємо RequiredLevel замість Reputation
    private List<ProductCatalogItem> AvailableProducts = new()
    {
        new ProductCatalogItem { Type = ProductType.Flour, Name = "Борошно", Icon = "🌾", Price = 10, RequiredLevel = 1 },
        new ProductCatalogItem { Type = ProductType.Sugar, Name = "Цукор", Icon = "🧊", Price = 15, RequiredLevel = 1 },
        new ProductCatalogItem { Type = ProductType.Eggs, Name = "Яйця", Icon = "🥚", Price = 25, RequiredLevel = 2 },
        new ProductCatalogItem { Type = ProductType.Milk, Name = "Молоко", Icon = "🥛", Price = 30, RequiredLevel = 2 },
        new ProductCatalogItem { Type = ProductType.Cocoa, Name = "Какао", Icon = "🍫", Price = 40, RequiredLevel = 3 }
    };

    public class ProductCatalogItem
    {
        public ProductType Type { get; set; }
        public string Name { get; set; } = "";
        public string Icon { get; set; } = "";
        public int Price { get; set; }
        public int RequiredLevel { get; set; } // Тепер працюємо по рівнях
    }

    private int TotalCartItems => cart.Values.Sum();
    private int TotalCartPrice => cart.Sum(c => c.Value * AvailableProducts.First(p => p.Type == c.Key).Price);
    private int TotalDeliveryTime => TotalCartItems > 0 ? 2 + (TotalCartItems / 2) : 0; // Трохи пришвидшив доставку

    protected override void OnInitialized() => State.OnChange += StateHasChanged;
    public void Dispose() { isDisposed = true; State.OnChange -= StateHasChanged; }

    private void AddToCart(ProductType type)
    {
        if (cart.ContainsKey(type)) cart[type]++;
        else cart[type] = 1;
    }

    private void RemoveFromCart(ProductType type)
    {
        if (cart.ContainsKey(type))
        {
            cart[type]--;
            if (cart[type] <= 0) cart.Remove(type);
        }
    }

    private async Task Checkout()
    {
        if (cart.Count == 0) return;

        if (State.SpendGold(TotalCartPrice))
        {
            showErrorMessage = false;
            isDelivering = true;
            deliverySecondsRemaining = TotalDeliveryTime;

            while (deliverySecondsRemaining > 0)
            {
                await Task.Delay(1000);
                deliverySecondsRemaining--;
                if (!isDisposed) StateHasChanged();
            }

            foreach (var item in cart)
            {
                State.AddToInventory(item.Key, item.Value);
            }

            cart.Clear();
            isDelivering = false;
        }
        else
        {
            showErrorMessage = true;
            await Task.Delay(2000);
            showErrorMessage = false;
        }
        if (!isDisposed) StateHasChanged();
    }
}