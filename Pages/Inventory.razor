@page "/inventory"
@using SweetBakeryQuest.Models
@using SweetBakeryQuest.Services
@using SweetBakeryQuest.Components
@inject GameState State
@implements IDisposable

<style>
    /* Стилі для карток переїхали сюди, але їх також можна винести в RecipeCard.razor.css */
    .active-card {
        border: 2px dashed #fbc02d;
        background-color: #fffde7;
    }

    .locked-card {
        border: 2px dashed #9e9e9e;
        background-color: #f5f5f5;
        position: relative;
        border-radius: 15px;
        overflow: hidden;
    }

    .blur-content {
        opacity: 0.3;
        filter: grayscale(100%);
        pointer-events: none;
        user-select: none;
    }

    .locked-overlay {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        z-index: 10;
        text-align: center;
        width: 80%;
        background: rgba(255, 255, 255, 0.9);
        padding: 15px 0;
        border-radius: 10px;
        border: 2px solid #9e9e9e;
    }
</style>

<div class="container mt-4" style="padding-bottom: 80px; margin-bottom: 120px;">

    <h3 class="text-center mb-4" style="color: #4e342e; font-weight: bold;">📦 Ваша Комора</h3>

    <div class="row mb-5">
        @if (State.Inventory.Count == 0)
        {
            <p class="text-center text-muted fs-5">Ваша комора порожня. Час відвідати магазин!</p>
        }
        else
        {
            @foreach (var item in State.Inventory)
            {
                <div class="col-md-3 col-sm-6 mb-3">
                    <div class="card p-3 shadow-sm text-center h-100" style="border-radius: 15px; border: 2px solid #8d6e63; background-color: #efebe9;">
                        <div class="display-4 mb-2">@GetIcon(item.Key)</div>
                        <h5 style="color: #5d4037; font-weight: bold;">@TranslateProduct(item.Key)</h5>
                        <p class="fs-5 mb-0">Кількість: <strong>@item.Value</strong></p>
                    </div>
                </div>
            }
        }
    </div>

    <div class="text-center mb-4">
        <h3 style="color: #4e342e; font-weight: bold;">📖 Довідник Пекаря</h3>
        <p class="text-muted mt-2">Тут описані всі рецепти. Використовуйте їх, щоб розрахувати необхідні інгредієнти для замовлень.</p>
    </div>

    <div class="row">
        @* Сортуємо рецепти: спочатку доступні (меншого рівня), потім складніші *@
        @foreach (var recipe in RecipeCatalog.AllRecipes.OrderBy(r => r.RequiredLevel))
        {
            <div class="col-md-4 col-sm-6 mb-4">
                @* Вся магія блокування тепер всередині самої картки! *@
                <RecipeCard RecipeItem="recipe" />
            </div>
        }
    </div>
</div>

@code {
    protected override void OnInitialized() => State.OnChange += StateHasChanged;
    public void Dispose() => State.OnChange -= StateHasChanged;

    private string GetIcon(ProductType type) => type switch
    {
        ProductType.Flour => "🌾",
        ProductType.Sugar => "🧊",
        ProductType.Eggs => "🥚",
        ProductType.Milk => "🥛",
        ProductType.Cocoa => "🍫",
        _ => "📦"
    };

    private string TranslateProduct(ProductType type) => type switch
    {
        ProductType.Flour => "Борошно",
        ProductType.Sugar => "Цукор",
        ProductType.Eggs => "Яйця",
        ProductType.Milk => "Молоко",
        ProductType.Cocoa => "Какао",
        _ => type.ToString()
    };
}