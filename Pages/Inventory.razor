@page "/inventory"
@using SweetBakeryQuest.Models
@using SweetBakeryQuest.Services
@inject GameState State
@implements IDisposable

<div class="container mt-4">
    <h3 class="text-center mb-4" style="color: #4e342e; font-weight: bold;">📦 Ваша Комора</h3>

    <div class="row mb-5">
        @if (State.Inventory.Count == 0)
        {
            <p class="text-center text-muted fs-5">Ваша комора порожня. Час відвідати магазин!</p>
        }
        else
        {
            @foreach (var item in State.Inventory)
            {
                <div class="col-md-3 col-sm-6 mb-3">
                    <div class="card p-3 shadow-sm text-center h-100" style="border-radius: 15px; border: 2px solid #8d6e63; background-color: #efebe9;">
                        <div class="display-4 mb-2">@GetIcon(item.Key)</div>
                        <h5 style="color: #5d4037; font-weight: bold;">@TranslateProduct(item.Key)</h5>
                        <p class="fs-5 mb-0">Кількість: <strong>@item.Value</strong></p>
                    </div>
                </div>
            }
        }
    </div>

    <h3 class="text-center mb-4" style="color: #4e342e; font-weight: bold;">📖 Довідник Пекаря</h3>
    <p class="text-center text-muted mb-4">Тут описані всі рецепти. Використовуйте їх, щоб розрахувати необхідні інгредієнти для замовлень.</p>

    <div class="row">
        @foreach (var recipe in RecipeCatalog.AllRecipes)
        {
            <div class="col-md-4 col-sm-6 mb-4">
                <div class="card h-100 shadow-sm" style="border-radius: 15px; border: 2px dashed #fbc02d; background-color: #fffde7;">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h4 class="card-title mb-0" style="color: #f57f17; font-weight: bold;">
                                @recipe.Icon @recipe.Name
                            </h4>
                            <span class="badge @(recipe.Difficulty == QuestDifficulty.Easy ? "bg-success" : "bg-warning text-dark") fs-6">
                                @recipe.Difficulty
                            </span>
                        </div>
                        <hr />

                        <p class="text-muted mb-2"><strong>На 1 порцію потрібно:</strong></p>
                        <ul class="list-group list-group-flush" style="background: transparent;">
                            @foreach (var ing in recipe.Ingredients)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center px-0" style="background: transparent; border-color: #ffe082;">
                                    <span>@GetIcon(ing.Key) @TranslateProduct(ing.Key)</span>
                                    <strong class="text-danger">x @ing.Value</strong>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    protected override void OnInitialized() => State.OnChange += StateHasChanged;
    public void Dispose() => State.OnChange -= StateHasChanged;

    private string GetIcon(ProductType type) => type switch
    {
        ProductType.Flour => "🌾",
        ProductType.Sugar => "🧊",
        ProductType.Eggs => "🥚",
        ProductType.Milk => "🥛",
        ProductType.Cocoa => "🍫",
        _ => "📦"
    };

    private string TranslateProduct(ProductType type) => type switch
    {
        ProductType.Flour => "Борошно",
        ProductType.Sugar => "Цукор",
        ProductType.Eggs => "Яйця",
        ProductType.Milk => "Молоко",
        ProductType.Cocoa => "Какао",
        _ => type.ToString()
    };
}