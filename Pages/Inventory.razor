@page "/inventory"
@implements IDisposable
@using SweetBakeryQuest.Models
@using SweetBakeryQuest.Services
@inject GameState State

<div class="container mt-4">
    <h3 class="text-center mb-4" style="color: #4e342e; font-weight: bold;">📦 Ваша Комора</h3>

    @if (State.Inventory.Count == 0 || State.Inventory.All(x => x.Value == 0))
    {
        <div class="alert alert-warning text-center shadow-sm" style="border-radius: 15px; background-color: #fff9c4; border-color: #fbc02d;">
            <h5 class="mb-0 text-dark">У коморі гуляє вітер 🌬️. Час завітати до Магазину!</h5>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var item in State.Inventory.Where(x => x.Value > 0))
            {
                <div class="col-md-3 col-sm-6 mb-3">
                    <div class="card p-3 shadow-sm text-center" style="border-radius: 15px; border: 2px solid #8d6e63; background-color: #fdf8e4; transition: 0.3s;">

                        <div class="display-3 mb-2">
                            @GetIcon(item.Key)
                        </div>

                        <h5 style="color: #5d4037; font-weight: bold;">
                            @TranslateProduct(item.Key)
                        </h5>

                        <div class="fs-4 mb-0 fw-bold text-success">
                            @item.Value шт.
                        </div>

                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    // Підписуємося на оновлення, щоб інвентар оновлювався в реальному часі
    protected override void OnInitialized() => State.OnChange += StateHasChanged;
    public void Dispose() => State.OnChange -= StateHasChanged;

    // Спеціальний помічник для красивих іконок
    private string GetIcon(ProductType type) => type switch
    {
        ProductType.Flour => "🌾",
        // Коли додаси нові інгредієнти, розкоментуй ці рядки:
        // ProductType.Sugar => "🧊",
        // ProductType.Cocoa => "🍫",
        // ProductType.Eggs => "🥚",
        _ => "📦"
    };

    // Помічник для перекладу назв з англійської (enum) на українську
    private string TranslateProduct(ProductType type) => type switch
    {
        ProductType.Flour => "Борошно",
        // ProductType.Sugar => "Цукор",
        // ProductType.Cocoa => "Какао",
        // ProductType.Eggs => "Яйця",
        _ => type.ToString()
    };
}